{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install dependencies",
      "type": "shell",
      "command": "npm ci",
      "problemMatcher": ["$tsc"],
      "group": "build"
    },
    {
      "label": "Build all packages",
      "type": "shell",
      "command": "npm run build:data-provider && npm run build:data-schemas && npm run build:api && npm run frontend",
      "problemMatcher": ["$tsc"],
      "group": "build"
    },
    {
      "label": "Start backend (dev)",
      "type": "shell",
      "command": "npm run backend:dev",
      "problemMatcher": ["$tsc"],
      "group": "test"
    },
    {
      "label": "Start backend (prod)",
      "type": "shell",
      "command": "npm run backend",
      "problemMatcher": ["$tsc"],
      "group": "test"
    }
  ]
}
